{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        // arrary
        "vmnicName": {
           "type": "array",
           "defaultValue": [ 
               "vm1-nic"
           ]
        },
        "vmhostName": { 
           "type": "array",
           "defaultValue": [ 
               "contoso1"
           ]
        },

        "publicIpAddressName": {
           "type": "array",
           "defaultValue": [ 
               "vm1-pip"
           ]
        },

        // value by params.json
        "virtualNetworkName": {
           "type": "string"
        },
        "publicIpAddressType": {
            "type": "string"
        },
        "location": {
            "type": "string"
        },
        "virtualMachineSize": {
            "type": "string"
        },
        "adminUsername": {
            "type": "string"
        },
        "networkSecurityGroupName": {
            "type": "string"
        },
        "adminPassword": {
            "type": "securestring"
        },
        "addressPrefix": {
            "type": "string"
        },
        "subnetName": {
            "type": "string"
        },
        "subnetPrefix": {
            "type": "string"
        },
        "storageAccountType": {
            "type": "string"
        }
    },
    "variables": {
        "vnetId": "[resourceId(resourceGroup().Name,'Microsoft.Network/virtualNetworks', parameters('virtualNetworkName'))]",
        "subnetRef": "[concat(variables('vnetId'), '/subnets/', parameters('subnetName'))]",
        "storageAccountName": "[concat(uniquestring(resourceGroup().id), '2017', 'sa')]"
    },
    "resources": [
        {
            "name": "[parameters('vmhostName')[CopyIndex()]]",
            "apiVersion": "2016-04-30-preview",
            "location": "[parameters('location')]",
            "type": "Microsoft.Compute/virtualMachines",
            "copy": { 
               "name": "hostname", 
               "count": "[length(parameters('vmhostName'))]"
             },
            "dependsOn": [
                "[concat('Microsoft.Network/networkInterfaces/', parameters('vmnicName')[CopyIndex()])]"
            ],
            "properties": {
                "osProfile": {
                   "computerName": "[parameters('vmhostName')[CopyIndex()]]",
                   "adminUsername": "[parameters('adminUsername')]",
                   "adminPassword": "[parameters('adminPassword')]",
                   "windowsConfiguration": {
                       "provisionVmAgent": "true"
                     }
                  },
                "hardwareProfile": {
                    "vmSize": "[parameters('virtualMachineSize')]"
                  },
               "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[resourceId('Microsoft.Network/networkInterfaces', parameters('vmnicName')[CopyIndex()])]"
                        }
                    ]
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "MicrosoftWindowsServer",
                        "offer": "WindowsServer",
                        "sku": "2016-Datacenter",
                        "version": "latest"
                    },
                    "osDisk": {
                        "name": "[concat(parameters('vmhostName')[CopyIndex()], 'disk')]",
                        "createOption": "fromImage"
                    },
                    "dataDisks": []
                }
            }
        },
        {
            "name": "[parameters('vmnicName')[CopyIndex()]]",
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2016-09-01",
            "location": "[parameters('location')]",
            "copy": { 
               "name": "nicname", 
               "count": "[length(parameters('vmnicName'))]"
             },
            "dependsOn": [
                "[concat('Microsoft.Network/virtualNetworks/', parameters('virtualNetworkName'))]",
                "[concat('Microsoft.Network/networkSecurityGroups/', parameters('networkSecurityGroupName'))]"
            ],
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipconfig1",
                        "properties": {
                            "subnet": {
                                "id": "[variables('subnetRef')]"
                            },
                            "privateIPAllocationMethod": "Dynamic",
                            "publicIpAddress": {
                                "id": "[resourceId(resourceGroup().name, 'Microsoft.Network/publicIpAddresses', parameters('publicIpAddressName')[CopyIndex()])]"
                            }
                        }
                    }
                ],
                "networkSecurityGroup": {
                    "id": "[resourceId(resourceGroup().Name, 'Microsoft.Network/networkSecurityGroups', parameters('networkSecurityGroupName'))]"
                }
            }
        },
       {
            "name": "[parameters('virtualNetworkName')]",
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2016-09-01",
            "location": "[parameters('location')]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "[parameters('addressPrefix')]"
                    ]
                },
                "subnets": [
                    {
                        "name": "[parameters('subnetName')]",
                        "properties": {
                            "addressPrefix": "[parameters('subnetPrefix')]"
                        }
                    }
                ]
            }
        },
        {

            "name": "[parameters('publicIpAddressName')[CopyIndex()]]",
            "copy": { 
               "name": "pipname", 
               "count": "[length(parameters('publicIpAddressName'))]"
             },
            "type": "Microsoft.Network/publicIpAddresses",
            "apiVersion": "2016-09-01",
            "location": "[parameters('location')]",
            "properties": {
                "publicIpAllocationMethod": "[parameters('publicIpAddressType')]"
            }
        },
        {
            "name": "[parameters('networkSecurityGroupName')]",
            "type": "Microsoft.Network/networkSecurityGroups",
            "apiVersion": "2016-09-01",
            "location": "[parameters('location')]",
            "properties": {
                "securityRules": [
                    {
                        "name": "default-allow-rdp",
                        "properties": {
                            "priority": 1000,
                            "sourceAddressPrefix": "167.220.234.105/32",
                            "protocol": "TCP",
                            "destinationPortRange": "3389",
                            "access": "Allow",
                            "direction": "Inbound",
                            "sourcePortRange": "*",
                            "destinationAddressPrefix": "*"
                        }
                    },
                    {
                        "name": "default-allow-winrm",
                        "properties": {
                            "priority": 1001,
                            "sourceAddressPrefix": "167.220.234.105/32",
                            "protocol": "TCP",
                            "destinationPortRange": "5985",
                            "access": "Allow",
                            "direction": "Inbound",
                            "sourcePortRange": "*",
                            "destinationAddressPrefix": "*"
                        }
                    }
                ]
            }
        },
      {
        "type": "Microsoft.Storage/storageAccounts",
        "name": "[variables('storageAccountName')]",
        "apiVersion": "2016-01-01",
        "location": "[resourceGroup().location]",
        "sku": {
            "name": "[parameters('storageAccountType')]"
        },
        "kind": "Storage", 
        "properties": {
        }
      },
      { 
          "apiVersion": "2015-01-01", 
          "name": "linkedTemplate", 
          "type": "Microsoft.Resources/deployments", 
          "properties": { 
            "mode": "incremental", 
            "templateLink": {
               "uri":"https://s3.ap-northeast-2.amazonaws.com/opsworld-deploy-filerepo-ap-northeast-2/tmp/azworkshop/linked-deploy.json",
               "contentVersion":"1.0.0.0"
            }
          } 
      } 
    ],
    "outputs": {
        "adminUsername": {
            "type": "string",
            "value": "[parameters('adminUsername')]"
        },
        "storageAccountName": {
            "type": "string",
            "value": "[variables('storageAccountName')]"
        }

    }
}